{
  "name": "discord-lavalink",
  "version": "1.1.0",
  "description": "A TypeScript wrapper for Lavalink with Discord.js integration",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "clean": "rimraf dist",
    "prebuild": "npm run clean"
  },
  "keywords": [
    "discord",
    "lavalink",
    "music",
    "bot",
    "audio",
    "discord.js",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TejasLamba2006/discord-lavalink.git"
  },
  "bugs": {
    "url": "https://github.com/TejasLamba2006/discord-lavalink/issues"
  },
  "homepage": "https://github.com/TejasLamba2006/discord-lavalink#readme",
  "dependencies": {
    "axios": "^1.9.0",
    "discord.js": "^14.19.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.8.0",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "eslint": "^8.49.0",
    "@types/ws": "^8.18.1",
    "jest": "^29.7.0",
    "jest-mock": "^29.7.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.3.2",
    "typescript": "^5.8.3",
    "ws": "^8.18.1"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=16.9.0"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ]
}