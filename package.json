{
  "name": "discord-lavalink",
  "version": "1.0.0",
  "description": "A TypeScript wrapper for Lavalink with Discord.js integration",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "docs": "typedoc --out docs src"
  },
  "keywords": [
    "discord",
    "lavalink",
    "music",
    "bot",
    "audio",
    "discord.js",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TejasLamba2006/discord-lavalink.git"
  },
  "bugs": {
    "url": "https://github.com/TejasLamba2006/discord-lavalink/issues"
  },
  "homepage": "https://github.com/TejasLamba2006/discord-lavalink#readme",
  "dependencies": {
    "@discordjs/voice": "^0.18.0",
    "axios": "^1.9.0",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "eslint": "^8.49.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "typedoc": "^0.25.0",
    "typescript": "^5.2.0",
    "vitest": "^3.1.2"
  },
  "peerDependencies": {
    "discord.js": "^14.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=16.9.0"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ]
}